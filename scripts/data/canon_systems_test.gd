static func get_preset_systems(preset_name: String = PRESET_TEST_GALAXY_PREPATCH7) -> Array[Dictionary]:
	if PRESET_SYSTEMS.has(preset_name):
		return _to_typed_systems((PRESET_SYSTEMS[preset_name] as Array).duplicate(true))
	return _to_typed_systems(SYSTEMS.duplicate(true))

static func _to_typed_systems(raw_systems: Array) -> Array[Dictionary]:
	var typed_systems: Array[Dictionary] = []
	for system_data in raw_systems:
		if system_data is Dictionary:
			typed_systems.append(system_data)
	return typed_systems

